pipeline {

    agent { label 'linux-agent' }

    options {
        timestamps()
        timeout(time: 1, unit: 'HOURS')
    }

    tools {
        maven 'maven'
    }

    stages {

        stage('Start') {
            steps {
                echo "=========================================="
                echo "Build Started at: ${new Date()}"
                echo "=========================================="
            }
        }

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Compile') {
            steps {
                sh 'mvn clean compile'
            }
        }

        stage('Unit Tests') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Package') {
            steps {
                sh 'mvn package'
            }
        }

        stage('Archive') {
            steps {
                archiveArtifacts artifacts: 'target/*.jar'
                archiveArtifacts artifacts: 'target/surefire-reports/**', allowEmptyArchive: true
            }
        }
    }

    post {
        always {
            junit allowEmptyResults: true, testResults: 'target/surefire-reports/*.xml'
            echo "=========================================="
            echo "Unit Test Results Processed and Archived"
            echo "=========================================="
            echo "Build Finished at: ${new Date()}"
            echo "=========================================="
        }
        success {
            echo "Build SUCCESS"
        }
        failure {
            echo "Build FAILED"
        }
    }
}
